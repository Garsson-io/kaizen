{
  "name": "@garsson-io/kaizen",
  "version": "0.1.0",
  "description": "Kaizen — continuous improvement plugin for Claude Code",
  "type": "module",
  "bin": {
    "kaizen-pre-push": "src/hooks/kaizen-host-entry.sh"
  },
  "scripts": {
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true",
    "build": "tsc && bash scripts/write-hook-build-marker.sh",
    "check:fast": "npm run typecheck && npm run test:fast",
    "test": "timeout --kill-after=10 120 vitest run",
    "test:fast": "timeout --kill-after=10 60 vitest run --changed origin/main --passWithNoTests --exclude 'src/e2e/**' --exclude '**/*.e2e.test.ts'",
    "test:ci": "timeout --kill-after=10 180 vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=artifacts/junit.xml",
    "test:ci:shard": "timeout --kill-after=10 180 vitest run --coverage --reporter=blob --coverage.reporter=json --coverage.thresholds.lines=0 --coverage.thresholds.statements=0 --coverage.thresholds.functions=0 --coverage.thresholds.branches=0",
    "test:ci:merge": "timeout --kill-after=10 180 vitest --mergeReports artifacts/vitest-blob --coverage --reporter=default --reporter=junit --outputFile.junit=artifacts/junit.xml",
    "test:e2e": "timeout --kill-after=10 120 vitest run src/e2e/",
    "test:e2e:live": "KAIZEN_LIVE_TEST=1 timeout --kill-after=10 120 vitest run src/e2e/",
    "test:e2e:skills": "KAIZEN_SKILL_TEST=1 timeout --kill-after=10 180 vitest run src/e2e/skill-change.test.ts",
    "test:hooks": "bash .claude/hooks/tests/run-all-tests.sh",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@dallay/agentsync": "^1.42.3",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "tsx": "^4.19.0",
    "unique-names-generator": "^4.7.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
